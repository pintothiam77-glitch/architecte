function matchesSearch(agent, query){
  if (!query) return true;
  const haystack = `${agent.nom} ${agent.prenom} ${agent.numero} ${agent.profession} ${agent.lieu} ${agent.contact}`.toLowerCase();
  return haystack.includes(query.toLowerCase());
}

