/* ============================================================
   UTILITAIRES
   ============================================================ */
function hashStr(s){ let h=0; for(let i=0;i<s.length;i++) h=(h*31+s.charCodeAt(i))>>>0; return h; }
function seededRandom(seed){ let s = seed || 1; return function(){ s=(s*1103515245+12345)>>>0; return (s>>>8)/0x1000000; }; }
function checkLetters(seed){ const h=hashStr(seed); const a=String.fromCharCode(65+(h%26)); const b=String.fromCharCode(65+(Math.floor(h/26)%26)); return `${a}${b}`; }
function regionCode(lieu){ if(!lieu || !lieu.trim()) return "SN"; const letters = lieu.replace(/[^a-zA-ZÀ-ÿ]/g,"").toUpperCase(); return (letters.slice(0,2)||"SN").padEnd(2,"X"); }
function generateImmatriculation(existingAgents, agentData){
  const year = new Date().getFullYear();
  const region = regionCode(agentData.lieu);
  const used = new Set(existingAgents.map(a=>a.numero).filter(Boolean));
  let seqNum = existingAgents.length + 1;
  let candidate;
  do {
    const seq = String(seqNum).padStart(5,"0");
    const chk = checkLetters(`${agentData.nom}${agentData.prenom}${agentData.lieu}${seq}`);
    candidate = `ASERGMV-${region}-${year}-${seq}-${chk}`;
    seqNum += 1;
  } while (used.has(candidate));
  return candidate;
}
function todayISO(){ return new Date().toISOString().slice(0,10); }
function addYearsISO(isoDate, years){ const d = new Date(isoDate); d.setFullYear(d.getFullYear()+years); return d.toISOString().slice(0,10); }
function formatDateFR(isoDate){ if(!isoDate) return "—"; const [y,m,d] = isoDate.split("-"); return `${d}/${m}/${y}`; }
function escapeHtml(s){ return (s==null?"":String(s)).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c])); }

/* ============================================================
   MOTIF "QR" DÉCORATIF DÉTERMINISTE
   ============================================================ */
function qrPatternSVG(seed, size){
  size = size || 96;
  const grid = 21;
  const rnd = seededRandom(hashStr(seed || "agent"));
  const cells = [];
  const finderSquares = [[0,0],[grid-7,0],[0,grid-7]];
  const isFinder = (x,y) => finderSquares.some(([zx,zy]) => x>=zx && x<zx+7 && y>=zy && y<zy+7);
  for (let y=0;y<grid;y++){
    for (let x=0;x<grid;x++){
      if (isFinder(x,y)) continue;
      if (rnd() > 0.56) cells.push([x,y]);
    }
  }
  let rects = cells.map(([x,y]) => `<rect x="${x}" y="${y}" width="1" height="1" fill="${COLORS.forestDeep}"/>`).join("");
  let finders = finderSquares.map(([fx,fy]) => `
    <g>
      <rect x="${fx}" y="${fy}" width="7" height="7" fill="${COLORS.forestDeep}"/>
      <rect x="${fx+1}" y="${fy+1}" width="5" height="5" fill="#FFFFFF"/>
      <rect x="${fx+2}" y="${fy+2}" width="3" height="3" fill="${COLORS.forestDeep}"/>
    </g>`).join("");
  return `<svg width="${size}" height="${size}" viewBox="0 0 ${grid} ${grid}">
    <rect width="${grid}" height="${grid}" fill="#FFFFFF"/>
    ${rects}
    ${finders}
  </svg>`;
}

/* ============================================================
   CODE-BARRES DÉCORATIF DÉTERMINISTE (pour le verso)
   ============================================================ */
function barcodeSVG(seed){
  const total = 320, h = 48;
  const rnd = seededRandom(hashStr(`bar-${seed || "agent"}`));
  const bars = [];
  let x = 2;
  while (x < total - 2) {
    const w = 1 + Math.floor(rnd() * 4);
    if (rnd() > 0.42) bars.push(`<rect x="${x}" y="4" width="${w}" height="${h - 8}" fill="${COLORS.forestDeep}"/>`);
    x += w + 1;
  }
  return `<svg width="100%" height="${h}" viewBox="0 0 ${total} ${h}" preserveAspectRatio="none" style="display:block;">
    <rect width="${total}" height="${h}" fill="#FFFFFF"/>
    ${bars.join("")}
  </svg>`;
}

