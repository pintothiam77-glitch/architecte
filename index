  document.getElementById("registry-title").textContent = `Agents enregistrés ${loading ? "" : `(${agents.length})`}`;
  document.getElementById("loading-note").style.display = loading ? "block" : "none";
  document.getElementById("empty-note").style.display = (!loading && agents.length === 0) ? "block" : "none";

  const missingCount = agents.filter(a => !a.photo).length;
  const noteEl = document.getElementById("missing-photos-note");
  if (!loading && agents.length > 0) {
    noteEl.textContent = missingCount > 0 ? `${missingCount} photo(s) restant(es) à ajouter` : "Toutes les photos sont renseignées";
  } else {
    noteEl.textContent = "";
  }

  document.getElementById("view-cards-btn").classList.toggle("active", registryView === "cards");
  document.getElementById("view-list-btn").classList.toggle("active", registryView === "list");
  document.getElementById("view-checklist-btn").classList.toggle("active", registryView === "checklist");

  const grid = document.getElementById("registry-grid");
  const tableWrap = document.getElementById("registry-table-wrap");
  const tableBody = document.getElementById("registry-table-body");
  const checklistWrap = document.getElementById("checklist-wrap");
  const checklistBody = document.getElementById("checklist-table-body");
  const checklistSummary = document.getElementById("checklist-summary");
  const controls = document.getElementById("registry-search");
  const noResultsNote = document.getElementById("no-results-note");
  const resultsCount = document.getElementById("results-count");
  controls.style.display = (loading || agents.length === 0) ? "none" : "block";

  grid.innerHTML = "";
  tableBody.innerHTML = "";
  checklistBody.innerHTML = "";
  if (loading || agents.length === 0) {
    grid.style.display = "grid";
    tableWrap.style.display = "none";
    checklistWrap.style.display = "none";
    checklistSummary.style.display = "none";
    noResultsNote.style.display = "none";
    resultsCount.textContent = "";
    return;
  }

  const filtered = agents.filter(a => matchesSearch(a, registrySearch));
  resultsCount.textContent = registrySearch
    ? `${filtered.length} / ${agents.length} agent(s)`
    : `${agents.length} agent(s) au total`;
  noResultsNote.style.display = filtered.length === 0 ? "block" : "none";

  grid.style.display = registryView === "cards" ? "grid" : "none";
  tableWrap.style.display = (registryView === "list" && filtered.length > 0) ? "block" : "none";
  checklistWrap.style.display = registryView === "checklist" ? "block" : "none";
  checklistSummary.style.display = registryView === "checklist" ? "flex" : "none";

  if (registryView === "cards") {
    filtered.forEach(agent => {
      const tile = document.createElement("div");
      tile.className = "agent-tile";
      tile.innerHTML = `
        <div class="agent-thumb-pair">
          <div class="agent-thumb-mini">
            <div class="agent-thumb-mini-inner">${renderAgentCardHTML(agent)}</div>
            <div class="agent-thumb-mini-tag">Recto</div>
          </div>
          <div class="agent-thumb-mini">
            <div class="agent-thumb-mini-inner">${renderAgentCardVersoHTML(agent)}</div>
            <div class="agent-thumb-mini-tag">Verso</div>
          </div>
        </div>
        <div class="agent-name">${escapeHtml(agent.prenom)} ${escapeHtml(agent.nom)}</div>
        <div class="agent-role">${escapeHtml(agent.profession || "—")}</div>
        ${!agent.photo ? `<div class="badge-missing">PHOTO MANQUANTE</div>` : ""}
        <div class="agent-actions">${actionButtonsHTML(agent)}</div>
      `;
      grid.appendChild(tile);
    });

    grid.querySelectorAll('[data-action="edit"]').forEach(btn => btn.addEventListener("click", () => startEdit(btn.dataset.id)));
    grid.querySelectorAll('[data-action="download"]').forEach(btn => btn.addEventListener("click", () => handleDownloadAgent(btn.dataset.id)));
    grid.querySelectorAll('[data-action="delete"]').forEach(btn => btn.addEventListener("click", () => handleDelete(btn.dataset.id)));
  } else if (registryView === "list") {
    filtered.forEach(agent => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="table-name">${escapeHtml(agent.prenom)} ${escapeHtml(agent.nom)}</td>
        <td>${escapeHtml(agent.profession || "—")}</td>
        <td>${escapeHtml(agent.lieu || "—")}</td>
        <td class="table-numero">${escapeHtml(agent.numero || "—")}</td>
        <td>${escapeHtml(agent.contact || "—")}</td>
        <td>
          <span class="table-photo-cell">
            <span class="table-photo-dot" style="background:${agent.photo ? COLORS.snGreen : COLORS.goldLight};"></span>
            ${agent.photo ? "Renseignée" : "Manquante"}
          </span>
        </td>
        <td><div class="table-actions">${actionButtonsHTML(agent)}</div></td>
      `;
      tableBody.appendChild(tr);
    });

    tableBody.querySelectorAll('[data-action="edit"]').forEach(btn => btn.addEventListener("click", () => startEdit(btn.dataset.id)));
    tableBody.querySelectorAll('[data-action="download"]').forEach(btn => btn.addEventListener("click", () => handleDownloadAgent(btn.dataset.id)));
    tableBody.querySelectorAll('[data-action="delete"]').forEach(btn => btn.addEventListener("click", () => handleDelete(btn.dataset.id)));
  } else {
    renderChecklistSummary(checklistSummary);

    const sorted = [...filtered].sort((a, b) => {
      const an = `${a.nom} ${a.prenom}`.toLowerCase();
      const bn = `${b.nom} ${b.prenom}`.toLowerCase();
      return an.localeCompare(bn, "fr");
    });

    sorted.forEach((agent, idx) => {
      const downloaded = downloadedIds.has(agent.id);
      const tr = document.createElement("tr");
      tr.innerHTML = `
