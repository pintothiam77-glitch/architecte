<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Registre des cartes professionnelles — ASR &amp; Grande Muraille Verte</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>

  :root{
    --forest-deep:#0B3423;
    --forest-mid:#124430;
    --gold:#C9A24B;
    --gold-light:#E8CD86;
    --cream:#F6F1E4;
    --white:#FFFFFF;
    --sn-green:#00853F;
    --sn-yellow:#FDEF42;
    --sn-red:#E31B23;
    --card-w:1013px;
    --card-h:638px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    min-height:100vh;
    background:linear-gradient(180deg,#08150F 0%, #0B1F16 100%);
    padding:40px 24px 80px;
    font-family:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
    color:var(--cream);
  }
  .wrap{max-width:1360px;margin:0 auto;}
  .spin{animation:spin 1s linear infinite;}
  @keyframes spin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}

  /* --- En-tête --- */
  .app-header{margin-bottom:32px;}
  .eyebrow-top{
    font-size:11px;letter-spacing:.22em;text-transform:uppercase;
    color:var(--gold-light);font-weight:700;margin-bottom:8px;
  }
  .app-header h1{font-size:28px;font-weight:800;color:var(--white);margin:0;}
  .app-header p{color:rgba(246,241,228,.6);margin-top:8px;font-size:14px;}

  /* --- Layout principal --- */
  .main-grid{display:grid;grid-template-columns:380px 1fr;gap:32px;}
  @media (max-width:900px){.main-grid{grid-template-columns:1fr;}}

  .form-panel{
    background:rgba(255,255,255,.04);
    border:1px solid rgba(232,205,134,.18);
    border-radius:16px;padding:24px;height:fit-content;
  }
  .form-panel h2{font-size:15px;font-weight:700;margin:0 0 18px;color:var(--gold-light);}

  .field{margin-bottom:14px;}
  .field label{
    display:block;font-size:11px;font-weight:700;letter-spacing:.08em;
    text-transform:uppercase;color:rgba(246,241,228,.55);margin-bottom:6px;
  }
  .field input{
    width:100%;padding:9px 12px;border-radius:8px;
    border:1px solid rgba(232,205,134,.25);
    background:rgba(255,255,255,.05);color:var(--white);
    font-size:13px;outline:none;box-sizing:border-box;
    font-family:inherit;
  }
  .field input::placeholder{color:rgba(246,241,228,.35);}
  .numero-row{display:flex;gap:8px;}
  .numero-row input{font-family:monospace;}
  .numero-hint{font-size:11px;color:rgba(246,241,228,.45);margin-top:4px;}

  .photo-upload-label{
    display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:8px;
    border:1px dashed rgba(232,205,134,.4);cursor:pointer;font-size:13px;color:var(--gold-light);
  }
  .photo-upload-label input{display:none;}

  .status-msg{font-size:12.5px;color:var(--gold-light);margin-bottom:14px;}

  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:8px;
    border:none;border-radius:9px;cursor:pointer;font-family:inherit;
    font-weight:700;font-size:13px;padding:10px 16px;
  }
  .btn-primary{
    background:linear-gradient(120deg,var(--gold-light),var(--gold));
    color:var(--forest-deep);flex:1;
  }
  .btn-primary:disabled{opacity:.6;cursor:not-allowed;}
  .btn-secondary{
    border:1px solid rgba(232,205,134,.4);
    background:transparent;color:var(--gold-light);
  }
  .btn-row{display:flex;gap:10px;}
  .btn-full{width:100%;margin-top:10px;}
  .icon-btn{
    display:flex;align-items:center;justify-content:center;width:30px;height:30px;
    border-radius:7px;border:1px solid rgba(232,205,134,.25);
    background:transparent;color:var(--gold-light);cursor:pointer;
  }
  .icon-btn.danger{color:#F0A0A0;}
  .icon-btn:disabled{opacity:.5;cursor:not-allowed;}

  /* --- Aperçu --- */
  .preview-box{width:620px;height:391px;max-width:100%;overflow:hidden;border-radius:16px;}
  .preview-scale{transform:scale(.612);transform-origin:top left;}
  .preview-stack{display:flex;flex-direction:column;gap:22px;}
  .card-side-label{
    display:flex;align-items:center;gap:8px;font-size:11px;font-weight:700;
    letter-spacing:.16em;text-transform:uppercase;color:var(--gold-light);opacity:.85;
  }
  .card-side-label .dot{width:6px;height:6px;border-radius:50%;background:var(--gold-light);}

  /* --- Registre --- */
  .registry-section{margin-top:48px;}
  .registry-header{display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
  .registry-header h2{font-size:17px;font-weight:700;color:var(--white);margin:0;}
  .registry-header .spacer{margin-left:auto;display:flex;gap:10px;flex-wrap:wrap;}
  .missing-photos-note{font-size:12.5px;color:rgba(246,241,228,.55);}
  .empty-note{color:rgba(246,241,228,.5);font-size:14px;}

  .registry-controls{
    display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:16px;
  }
  .search-input{
    flex:1;min-width:220px;padding:9px 14px;border-radius:8px;
    border:1px solid rgba(232,205,134,.25);background:rgba(255,255,255,.05);
    color:var(--white);font-size:13px;font-family:inherit;outline:none;box-sizing:border-box;
  }
  .search-input::placeholder{color:rgba(246,241,228,.35);}
  .view-toggle{display:flex;border:1px solid rgba(232,205,134,.3);border-radius:9px;overflow:hidden;flex-shrink:0;}
  .view-toggle button{
    padding:9px 16px;background:transparent;border:none;color:rgba(246,241,228,.6);
    font-size:12.5px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap;
  }
  .view-toggle button.active{background:linear-gradient(120deg,var(--gold-light),var(--gold));color:var(--forest-deep);}
  .results-count{font-size:12.5px;color:rgba(246,241,228,.5);white-space:nowrap;}

  .registry-table-wrap{
    overflow-x:auto;border:1px solid rgba(232,205,134,.16);border-radius:14px;
    background:rgba(255,255,255,.02);
  }
  .registry-table{width:100%;border-collapse:collapse;font-size:13px;min-width:760px;}
  .registry-table th{
    text-align:left;font-size:10.5px;text-transform:uppercase;letter-spacing:.08em;
    color:var(--gold-light);padding:11px 14px;border-bottom:1px solid rgba(232,205,134,.22);
    background:rgba(255,255,255,.03);white-space:nowrap;position:sticky;top:0;
  }
  .registry-table td{
    padding:9px 14px;border-bottom:1px solid rgba(255,255,255,.05);
    color:var(--cream);vertical-align:middle;
  }
  .registry-table tr:last-child td{border-bottom:none;}
  .registry-table tr:hover td{background:rgba(255,255,255,.035);}
  .table-name{font-weight:700;color:var(--white);white-space:nowrap;}
  .table-numero{font-family:monospace;font-size:12px;color:rgba(246,241,228,.75);white-space:nowrap;}
  .table-photo-dot{
    display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;flex-shrink:0;
  }
  .table-photo-cell{display:flex;align-items:center;font-size:12px;color:rgba(246,241,228,.6);white-space:nowrap;}
  .table-actions{display:flex;gap:6px;white-space:nowrap;}

  .checklist-summary{
    display:flex;gap:22px;flex-wrap:wrap;align-items:center;margin-bottom:16px;
    padding:12px 16px;border-radius:12px;background:rgba(255,255,255,.04);
    border:1px solid rgba(232,205,134,.16);
  }
  .checklist-stat{display:flex;flex-direction:column;gap:4px;min-width:150px;}
  .checklist-stat-label{
    font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
    color:var(--gold-light);opacity:.8;
  }
  .checklist-stat-value{font-size:15px;font-weight:700;color:var(--white);}
  .checklist-bar{height:6px;border-radius:4px;background:rgba(255,255,255,.08);overflow:hidden;min-width:150px;}
  .checklist-bar-fill{height:100%;background:linear-gradient(90deg,var(--gold-light),var(--gold));border-radius:4px;}

  .checklist-toolbar{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:14px;flex-wrap:wrap;}
  .checklist-intro{font-size:12.5px;color:rgba(246,241,228,.6);max-width:560px;line-height:1.5;}
  .checklist-checkbox{width:18px;height:18px;cursor:pointer;accent-color:var(--gold);}
  .checklist-checkbox:disabled{cursor:default;opacity:.85;}
  .table-numero-cell{font-family:monospace;font-size:11.5px;color:rgba(246,241,228,.7);white-space:nowrap;}

  @media print{
    body.printing-checklist *{visibility:hidden;}
    body.printing-checklist #checklist-wrap,
    body.printing-checklist #checklist-wrap *{visibility:visible;}
    body.printing-checklist #checklist-wrap{
      position:absolute;top:0;left:0;width:100%;background:#fff;padding:12mm;box-sizing:border-box;
    }
    body.printing-checklist #checklist-toolbar{display:none !important;}
    body.printing-checklist .registry-table-wrap{border:none;background:#fff;}
    body.printing-checklist .registry-table th{
      background:#0B3423 !important;color:#E8CD86 !important;
      -webkit-print-color-adjust:exact;print-color-adjust:exact;
    }
    body.printing-checklist .registry-table td,
    body.printing-checklist .registry-table th{color:#000;border-color:#ccc;}
    body.printing-checklist .registry-table th{color:#E8CD86 !important;}
  }

  .registry-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;
  }
  .agent-tile{
    background:rgba(255,255,255,.04);border:1px solid rgba(232,205,134,.16);
    border-radius:14px;padding:14px;
  }
  .agent-thumb-pair{display:flex;gap:8px;}
  .agent-thumb-mini{
    position:relative;width:130px;height:82px;overflow:hidden;border-radius:8px;
    border:1px solid rgba(232,205,134,.18);flex-shrink:0;
  }
  .agent-thumb-mini-inner{position:absolute;top:0;left:0;transform:scale(.1283);transform-origin:top left;}
  .agent-thumb-mini-tag{
    position:absolute;bottom:3px;right:5px;z-index:2;font-family:system-ui,sans-serif;
    font-size:8px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;
    color:var(--gold-light);background:rgba(11,52,35,.75);border-radius:3px;padding:1px 5px;
  }
  .agent-name{margin-top:10px;font-size:14px;font-weight:700;color:var(--white);}
  .agent-role{font-size:12.5px;color:rgba(246,241,228,.55);margin-bottom:8px;}
  .badge-missing{
    display:inline-block;font-size:10.5px;font-weight:700;letter-spacing:.04em;
    color:#F0C77A;background:rgba(232,205,134,.12);border:1px solid rgba(232,205,134,.3);
    border-radius:6px;padding:3px 8px;margin-bottom:10px;
  }
  .agent-actions{display:flex;gap:8px;}

  /* --- Carte agent (structure générée en JS) --- */
  .agent-card-outer{
    position:relative;width:var(--card-w);height:var(--card-h);border-radius:22px;
    overflow:hidden;
    background:linear-gradient(135deg,var(--forest-deep) 0%, var(--forest-mid) 48%, #0D2E20 100%);
    box-shadow:0 40px 80px -20px rgba(0,0,0,.6), 0 10px 30px rgba(0,0,0,.4);
    border:1px solid rgba(201,162,75,.35);
    font-family:Georgia,'Times New Roman',serif;
  }
  .agent-card-security{position:absolute;inset:0;z-index:0;opacity:.08;pointer-events:none;}
  .agent-card-panel{
    position:absolute;top:28px;left:28px;right:28px;bottom:28px;border-radius:16px;
    background:rgba(255,255,255,.05);border:1px solid rgba(232,205,134,.25);
    display:flex;flex-direction:column;justify-content:space-between;
    padding:32px 40px 24px 40px;z-index:1;
  }
  .card-header-row{display:flex;align-items:center;gap:16px;}
  .card-logo-slot{
    width:64px;height:64px;border-radius:50%;border:2px solid var(--gold-light);
    overflow:hidden;flex-shrink:0;background:var(--white);
    display:flex;align-items:center;justify-content:center;box-shadow:0 2px 10px rgba(0,0,0,.3);
  }
  .card-logo-slot img{width:100%;height:100%;object-fit:cover;}
  .card-institution{display:flex;flex-direction:column;gap:4px;}
  .card-eyebrow{
    font-family:system-ui,sans-serif;font-size:11px;font-weight:700;letter-spacing:.2em;
    text-transform:uppercase;color:var(--gold-light);opacity:.85;
  }
  .card-institution-title{
    font-style:italic;font-weight:700;font-size:21px;color:var(--cream);
    line-height:1.25;max-width:540px;
  }
  .card-official-tag{
    margin-left:auto;text-align:right;font-family:system-ui,sans-serif;font-size:9.5px;
    font-weight:800;letter-spacing:.14em;color:var(--gold-light);line-height:1.5;
    border:1px solid rgba(232,205,134,.4);border-radius:6px;padding:6px 10px;opacity:.9;
  }
  .card-divider{
    height:1px;width:100%;margin:20px 0 18px 0;
    background:linear-gradient(90deg, rgba(201,162,75,0) 0%, rgba(232,205,134,.55) 18%, rgba(232,205,134,.55) 82%, rgba(201,162,75,0) 100%);
  }
  .card-identity-row{display:flex;align-items:flex-end;justify-content:space-between;gap:26px;}
  .card-photo-slot{
    width:112px;height:112px;border-radius:50%;border:3px solid var(--gold-light);
    overflow:hidden;flex-shrink:0;background:rgba(255,255,255,.06);
    display:flex;align-items:center;justify-content:center;
  }
  .card-photo-slot img{width:100%;height:100%;object-fit:cover;}
  .card-photo-placeholder{
    font-family:system-ui,sans-serif;font-size:11px;letter-spacing:.06em;
    color:rgba(232,205,134,.6);text-align:center;line-height:1.3;
  }
  .card-prenom{
    font-family:system-ui,sans-serif;font-weight:500;font-size:20px;letter-spacing:.04em;
    color:rgba(246,241,228,.8);text-transform:uppercase;margin-bottom:2px;
  }
  .card-nom{
    font-weight:700;font-size:44px;letter-spacing:.02em;color:var(--white);
    line-height:1.05;text-shadow:0 2px 14px rgba(0,0,0,.35);
  }
  .card-fonction-badge{
    margin-top:12px;display:inline-block;font-family:system-ui,sans-serif;font-weight:700;
    font-size:13.5px;letter-spacing:.04em;color:var(--forest-deep);
    background:linear-gradient(120deg,var(--gold-light),var(--gold));padding:6px 14px;border-radius:5px;
  }
  .card-lieu{
    margin-top:10px;font-family:system-ui,sans-serif;font-size:13px;
    color:rgba(246,241,228,.65);letter-spacing:.02em;
  }
  .card-footer-block{display:flex;flex-direction:column;gap:16px;}
  .card-meta-info{display:flex;gap:34px;flex-wrap:wrap;align-items:flex-end;}
  .card-meta-label{
    font-family:system-ui,sans-serif;font-size:9.5px;font-weight:700;letter-spacing:.16em;
    text-transform:uppercase;color:var(--gold-light);opacity:.8;margin-bottom:4px;
  }
  .card-meta-value{font-family:system-ui,sans-serif;font-size:14px;font-weight:600;color:var(--cream);}
  .card-meta-value.meta-primary{
    font-size:17px;font-weight:700;letter-spacing:.02em;color:var(--white);
  }
  .card-meta-value.meta-numero{
    font-family:monospace;letter-spacing:.02em;white-space:nowrap;
  }
  .card-meta-value.meta-secondary{font-size:12.5px;font-weight:500;color:rgba(246,241,228,.7);}
  .card-bottom-row{display:flex;align-items:flex-end;justify-content:space-between;}
  .card-signature-line{width:150px;border-bottom:1px solid rgba(232,205,134,.5);margin-bottom:4px;}
  .card-signature-label{
    font-family:system-ui,sans-serif;font-size:9.5px;letter-spacing:.12em;
    text-transform:uppercase;color:rgba(246,241,228,.45);
  }
  .card-flag-badge{display:flex;align-items:center;gap:8px;}
  .card-flag-stripes{
    width:40px;height:27px;border-radius:3px;overflow:hidden;display:flex;
    border:1px solid rgba(255,255,255,.25);
  }
  .card-base-strip{
    position:absolute;left:0;right:0;bottom:0;height:8px;
    background:linear-gradient(90deg, var(--sn-green) 0 33.3%, var(--sn-yellow) 33.3% 66.6%, var(--sn-red) 66.6% 100%);
  }

  /* --- Verso de la carte --- */
  .verso-body{display:flex;justify-content:space-between;gap:28px;margin-top:6px;}
  .verso-terms{max-width:640px;}
  .verso-terms-list{
    margin:8px 0 0;padding-left:18px;font-family:system-ui,sans-serif;font-size:12.5px;
    line-height:1.75;color:rgba(246,241,228,.82);
  }
  .verso-terms-list li{margin-bottom:4px;}
  .verso-qr-block{display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0;}
  .verso-qr-caption{
    font-family:system-ui,sans-serif;font-size:8.5px;letter-spacing:.1em;text-transform:uppercase;
    color:rgba(232,205,134,.65);text-align:center;
  }
  .verso-barcode{
    background:#FFFFFF;border-radius:6px;padding:8px 10px;width:100%;box-sizing:border-box;
  }
  .verso-barcode-caption{
    font-family:monospace;font-size:10px;letter-spacing:.12em;color:var(--forest-deep);
    text-align:center;margin-top:2px;
  }

  /* Icônes minimalistes (SVG inline, pas de dépendance externe) */
  .ic{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
</style>
</head>
<body>
  <div class="wrap">
    <div class="app-header">
      <div class="eyebrow-top">République du Sénégal</div>
      <h1>Registre des cartes professionnelles — ASR &amp; Grande Muraille Verte</h1>
      <p>Créez, modifiez, enregistrez et téléchargez la carte de chaque agent.</p>
    </div>

    <div class="main-grid">
      <!-- Formulaire -->
      <div class="form-panel">
        <h2 id="form-title">Nouvel agent</h2>

        <div class="field">
          <label>Nom</label>
          <input id="f-nom" placeholder="Diop" />
        </div>
        <div class="field">
          <label>Prénom</label>
          <input id="f-prenom" placeholder="Awa" />
        </div>
        <div class="field">
          <label>Profession / Fonction</label>
          <input id="f-profession" placeholder="Ingénieure agroforestière" />
        </div>
        <div class="field">
          <label>Lieu d'affectation</label>
          <input id="f-lieu" placeholder="Kaolack, Sénégal" />
        </div>
        <div class="field">
          <label>Immatriculation officielle</label>
          <div class="numero-row">
            <input id="f-numero" placeholder="Générée automatiquement" />
            <button class="btn btn-secondary" id="btn-regen" title="Générer / régénérer" style="padding:9px 12px;">
              <svg class="ic" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            </button>
          </div>
          <div class="numero-hint">Chaque agent reçoit une immatriculation unique (région + année + séquence + clé de contrôle). Laissez vide pour génération automatique à l'enregistrement.</div>
        </div>
        <div class="field">
          <label>Contact (téléphone ou email)</label>
          <input id="f-contact" placeholder="+221 77 000 00 00" />
        </div>

        <div class="field">
          <label>Photo de l'agent</label>
          <label class="photo-upload-label" id="photo-upload-label">
            <svg class="ic" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <span id="photo-upload-text">Importer une photo</span>
            <input type="file" accept="image/*" id="f-photo-input" />
          </label>
        </div>

        <div class="status-msg" id="status-msg" style="display:none;"></div>

        <div class="btn-row">
          <button class="btn btn-primary" id="btn-save">
            <svg class="ic" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <span id="btn-save-text">Enregistrer l'agent</span>
          </button>
          <button class="btn btn-secondary" id="btn-cancel-edit" style="display:none;padding:10px 14px;">
            <svg class="ic" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <button class="btn btn-secondary btn-full" id="btn-download-current">
          <svg class="ic" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Télécharger recto + verso (PNG)
        </button>
      </div>

      <!-- Aperçu en direct : recto + verso -->
      <div class="preview-stack">
        <div>
          <div class="card-side-label"><span class="dot"></span>Recto</div>
          <div class="preview-box" style="margin-top:8px;">
            <div class="preview-scale" id="preview-card-mount"></div>
          </div>
        </div>
        <div>
          <div class="card-side-label"><span class="dot"></span>Verso</div>
