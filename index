let agents = [];
let loading = true;
let form = { ...emptyForm };
let saving = false;
let downloadingId = null;
let statusMsg = "";
let registryView = "list";
let registrySearch = "";
let downloadedIds = new Set();
const DOWNLOADED_KEY = "downloaded-agents";

function buildAgentsFromSeed(){
  const built = [];
  const today = todayISO();
  RAW_SEED_AGENTS.forEach((raw, i) => {
    const base = { ...emptyForm, ...raw };
    const numero = generateImmatriculation(built, base);
    built.push({ ...base, id: `seed-${i}-${Date.now()}`, numero, photo:"", dateDelivrance: today, validite: addYearsISO(today, 3) });
  });
  return built;
}

async function persist(nextAgents){
  try {
    await window.storage.set(STORAGE_KEY, JSON.stringify(nextAgents), false);
    return true;
  } catch (e) {
    setStatus("Échec de l'enregistrement — réessayez.");
    return false;
  }
}

function setStatus(msg){
  statusMsg = msg;
  const el = document.getElementById("status-msg");
  if (msg) { el.style.display = "block"; el.textContent = msg; }
  else { el.style.display = "none"; el.textContent = ""; }
}

