function renderChecklistSummary(el){
  const total = agents.length;
  const photoCount = agents.filter(a => a.photo).length;
  const downloadCount = agents.filter(a => downloadedIds.has(a.id)).length;
  const pct = total ? Math.round((downloadCount / total) * 100) : 0;
  el.innerHTML = `
    <div class="checklist-stat">
      <span class="checklist-stat-label">Photos ajoutées</span>
      <span class="checklist-stat-value">${photoCount} / ${total}</span>
    </div>
    <div class="checklist-stat">
      <span class="checklist-stat-label">Cartes téléchargées</span>
      <span class="checklist-stat-value">${downloadCount} / ${total}</span>
    </div>
    <div class="checklist-stat" style="flex:1;">
      <span class="checklist-stat-label">Progression globale — ${pct}%</span>
      <div class="checklist-bar"><div class="checklist-bar-fill" style="width:${pct}%;"></div></div>
    </div>
  `;
}

async function persistDownloaded(){
  try {
    await window.storage.set(DOWNLOADED_KEY, JSON.stringify([...downloadedIds]), false);
  } catch (e) { /* stockage best-effort */ }
}

async function toggleDownloaded(id, checked){
  if (checked) downloadedIds.add(id); else downloadedIds.delete(id);
  renderRegistry();
  await persistDownloaded();
}

function renderAll(){ renderForm(); renderPreview(); renderRegistry(); }

/* ============================================================
   ACTIONS
   ============================================================ */
function startNew(){
  form = { ...emptyForm, numero: "" };
  setStatus("");
  renderAll();
}

function startEdit(id){
  const agent = agents.find(a => a.id === id);
  if (!agent) return;
  form = { ...agent };
  setStatus("");
  renderAll();
  window.scrollTo({ top: 0, behavior: "smooth" });
}

function regenerateNumero(){
  if (!form.nom.trim() && !form.prenom.trim()) {
    setStatus("Renseignez au moins le nom pour générer une immatriculation.");
    return;
  }
  form.numero = generateImmatriculation(agents.filter(a => a.id !== form.id), form);
  renderForm();
}

async function handleSave(){
  if (!form.nom.trim() || !form.prenom.trim()) { setStatus("Nom et prénom sont requis."); return; }
  saving = true; renderForm();
  const isEdit = !!form.id;
  const otherAgents = agents.filter(a => a.id !== form.id);
  const dateDelivrance = form.dateDelivrance || todayISO();
  const record = {
    ...form,
    id: form.id || `${Date.now()}`,
    numero: form.numero || generateImmatriculation(otherAgents, form),
    dateDelivrance,
    validite: form.validite || addYearsISO(dateDelivrance, 3),
  };
  const next = isEdit ? agents.map(a => a.id === record.id ? record : a) : [...agents, record];
  const ok = await persist(next);
  if (ok) {
    agents = next;
    setStatus(isEdit ? "Fiche mise à jour." : "Agent enregistré dans le registre — immatriculation attribuée.");
    form = { ...emptyForm, numero: "" };
  }
  saving = false;
  renderAll();
}

async function handleDelete(id){
  const ok = window.confirm("Supprimer définitivement cette carte du registre ?");
  if (!ok) return;
  const next = agents.filter(a => a.id !== id);
  const success = await persist(next);
  if (success) { agents = next; renderAll(); }
}

async function handleDownloadCurrent(){
  const rectoNode = document.getElementById("preview-card-mount").firstElementChild;
  const versoNode = document.getElementById("preview-card-mount-verso").firstElementChild;
  if (!rectoNode || !versoNode) return;
  try {
    const base = `${(form.nom||"agent").toLowerCase()}-${(form.prenom||"").toLowerCase()}`;
    await exportNodeAsPng(rectoNode, `carte-${base}-recto.png`);
    await exportNodeAsPng(versoNode, `carte-${base}-verso.png`);
    if (form.id) {
      downloadedIds.add(form.id);
      await persistDownloaded();
      renderRegistry();
    }
  } catch (e) { setStatus("Le téléchargement a échoué. Réessayez."); }
}

async function handleDownloadAgent(id){
  const agent = agents.find(a => a.id === id);
  if (!agent) return;
  downloadingId = id;
  renderRegistry();
  const mount = document.getElementById("hidden-export-mount");
  const base = `${(agent.nom||"agent").toLowerCase()}-${(agent.prenom||"").toLowerCase()}`;
  try {
    mount.innerHTML = renderAgentCardHTML(agent);
    await new Promise(r => setTimeout(r, 60));
    await exportNodeAsPng(mount.firstElementChild, `carte-${base}-recto.png`);

    mount.innerHTML = renderAgentCardVersoHTML(agent);
    await new Promise(r => setTimeout(r, 60));
    await exportNodeAsPng(mount.firstElementChild, `carte-${base}-verso.png`);

    downloadedIds.add(id);
    await persistDownloaded();
  } catch (e) {
    setStatus("Le téléchargement a échoué. Réessayez.");
  } finally {
    downloadingId = null;
    mount.innerHTML = "";
    renderRegistry();
  }
}

async function handleApplyProfession(){
  if (loading || agents.length === 0) return;
  const ok = window.confirm(`Appliquer « ${DEFAULT_PROFESSION} » comme fonction pour les ${agents.length} agents du registre ? Les photos et autres informations ne seront pas modifiées.`);
  if (!ok) return;
  const updated = agents.map(a => ({ ...a, profession: DEFAULT_PROFESSION }));
  const success = await persist(updated);
  if (success) {
    agents = updated;
    if (form.id) form.profession = DEFAULT_PROFESSION;
    setStatus(`Fonction « ${DEFAULT_PROFESSION} » appliquée à ${updated.length} agent(s).`);
  } else {
    setStatus("La mise à jour a échoué. Réessayez.");
  }
  renderAll();
}

async function handleReimportSeed(){
  const ok = window.confirm("Réimporter le registre ASERGMV (90 agents) ? Cela remplacera la liste actuelle.");
  if (!ok) return;
  loading = true; renderRegistry();
  const seeded = buildAgentsFromSeed();
  const success = await persist(seeded);
  if (success) { agents = seeded; setStatus(`${seeded.length} agents réimportés — ajoutez les photos.`); }
  loading = false;
  renderAll();
}

async function handlePhoto(e){
  const file = e.target.files && e.target.files[0];
  if (!file) return;
  try {
    const dataUrl = await resizeImageFile(file);
    form.photo = dataUrl;
    renderAll();
  } catch (err) { setStatus("Impossible de charger cette photo."); }
}

/* ============================================================
   ÉVÉNEMENTS
   ============================================================ */
document.getElementById("f-nom").addEventListener("input", e => { form.nom = e.target.value; renderPreview(); });
document.getElementById("f-prenom").addEventListener("input", e => { form.prenom = e.target.value; renderPreview(); });
document.getElementById("f-profession").addEventListener("input", e => { form.profession = e.target.value; renderPreview(); });
document.getElementById("f-lieu").addEventListener("input", e => { form.lieu = e.target.value; renderPreview(); });
document.getElementById("f-numero").addEventListener("input", e => { form.numero = e.target.value; renderPreview(); });
document.getElementById("f-contact").addEventListener("input", e => { form.contact = e.target.value; renderPreview(); });
document.getElementById("f-photo-input").addEventListener("change", handlePhoto);
document.getElementById("btn-regen").addEventListener("click", regenerateNumero);
document.getElementById("btn-save").addEventListener("click", handleSave);
document.getElementById("btn-cancel-edit").addEventListener("click", startNew);
document.getElementById("btn-download-current").addEventListener("click", handleDownloadCurrent);
document.getElementById("btn-new-agent").addEventListener("click", startNew);
document.getElementById("btn-reimport").addEventListener("click", handleReimportSeed);
document.getElementById("btn-apply-profession").addEventListener("click", handleApplyProfession);
document.getElementById("registry-search").addEventListener("input", e => { registrySearch = e.target.value; renderRegistry(); });
document.getElementById("view-cards-btn").addEventListener("click", () => { registryView = "cards"; renderRegistry(); });
document.getElementById("view-list-btn").addEventListener("click", () => { registryView = "list"; renderRegistry(); });
document.getElementById("view-checklist-btn").addEventListener("click", () => { registryView = "checklist"; renderRegistry(); });
document.getElementById("btn-print-checklist").addEventListener("click", () => {
  document.body.classList.add("printing-checklist");
  window.print();
});
window.addEventListener("afterprint", () => document.body.classList.remove("printing-checklist"));

/* ============================================================
   CHARGEMENT INITIAL
   ============================================================ */
(async function init(){
  form = { ...emptyForm };
  renderAll();
  try {
    const res = await window.storage.get(STORAGE_KEY, false);
    const stored = res && res.value ? JSON.parse(res.value) : [];
    if (stored.length > 0) {
      agents = stored;
    } else {
      const seeded = buildAgentsFromSeed();
      await persist(seeded);
      agents = seeded;
      setStatus(`${seeded.length} agents importés depuis le registre ASERGMV — ajoutez les photos.`);
    }
  } catch (e) {
    agents = [];
  }
  try {
    const dres = await window.storage.get(DOWNLOADED_KEY, false);
    downloadedIds = new Set(dres && dres.value ? JSON.parse(dres.value) : []);
  } catch (e) {
    downloadedIds = new Set();
  }
  loading = false;
  renderAll();
})();

</script>
